<Window x:Class="JobSniper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JobSniper - My career zen" Height="800" Width="1200" 
        WindowStartupLocation="CenterScreen" Background="#F0F2F5" FontFamily="Segoe UI" Icon="pack://application:,,,/sniper1.ico">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="🎯 JobSniper" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Button x:Name="BtnDashboard" Click="BtnDashboard_Click" Content="📊 Dashboard" Height="45" Margin="10,5" Background="#34495E" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="BtnTridicka" Click="BtnTridicka_Click" Content="📥 Inbox (0)" Height="45" Margin="10,5" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                <Button x:Name="BtnPrilezitosti" Click="BtnPrilezitosti_Click" Content="⭐ Opportunities (0)" Height="45" Margin="10,5" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                <Button x:Name="BtnKos" Click="BtnKos_Click" Content="🗑️ Trash (0)" Height="45" Margin="10,5" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                <Button x:Name="BtnArchiv" Click="BtnArchiv_Click" Content="🗄️ Archive (Expired)" Height="45" Margin="10,5" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                <Button x:Name="BtnDuplicity" Click="BtnDuplicity_Click" Content="🔁 Session Duplicates (0)" Height="45" Margin="10,5" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>

                <Button x:Name="BtnSettings" Click="BtnSettings_Click" Content="⚙️ Settings &amp; Filters" Height="45" Margin="10,5" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
            </StackPanel>
        </Border>

        <Grid x:Name="GridDashboard" Grid.Column="1" Margin="30" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Dashboard / Overview" FontSize="32" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,20"/>

            <Grid Grid.Row="1" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Waiting in Inbox" FontSize="14" Foreground="#7F8C8D"/>
                        <TextBlock x:Name="TxtCekaVTridicce" Text="0" FontSize="36" FontWeight="Bold" Foreground="#2980B9" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" Margin="10,0,10,0">
                    <StackPanel>
                        <TextBlock Text="My Opportunities" FontSize="14" Foreground="#7F8C8D"/>
                        <TextBlock x:Name="TxtMojePrilezitosti" Text="0" FontSize="36" FontWeight="Bold" Foreground="#27AE60" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Trashed: Auto / Manual" FontSize="14" Foreground="#7F8C8D"/>
                        <TextBlock x:Name="TxtZahozeno" Text="0 / 0" FontSize="36" FontWeight="Bold" Foreground="#E74C3C" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Background processes (Scraper)" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="#333"/>
                    <TextBox Name="TxtConsoleLog" Grid.Row="1" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Background="#1E1E1E" Foreground="LightGreen" FontFamily="Consolas" Padding="10"/>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="GridTridicka" Grid.Column="1" Margin="30" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TxtTridickaTitle" Grid.Row="0" Text="📥 Inbox" FontSize="32" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,20"/>

            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10">
                <DataGrid Name="DataGridJobs" AutoGenerateColumns="False" IsReadOnly="True" Background="White" RowBackground="#F8F9FA" AlternatingRowBackground="White" BorderBrush="#EEE" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEE" VerticalContentAlignment="Center">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Position" Binding="{Binding Title}" Width="*" />

                        <DataGridTemplateColumn Header="Company" Width="180" SortMemberPath="Company">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Company}" Margin="5,0" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="3">
                                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="ToolTip" Value="This company is blacklisted (Automatically trashed)"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="150" />
                        <DataGridTextColumn Header="Seen" Binding="{Binding LastSeen, StringFormat=\{0:dd.MM. HH:mm\}}" Width="100" />
                        <DataGridTextColumn Header="Salary" Binding="{Binding Salary}" Width="130" />

                        <DataGridTemplateColumn Header="Actions" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="🌐 Web" Tag="{Binding Url}" Click="BtnOpenWeb_Click" Margin="0,0,5,0" Padding="8,3" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                        <Button Content="👍" ToolTip="Move to opportunities" Tag="{Binding}" Click="BtnZajimave_Click" Margin="0,0,5,0" Padding="8,3" Background="#2ECC71" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                        <Button Content="👎" ToolTip="Move to trash" Tag="{Binding}" Click="BtnSkryt_Click" Margin="0,0,5,0" Padding="8,3" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                                        <Button Content="⛔" ToolTip="Block company" Tag="{Binding}" Click="BtnBlokovatFirmu_Click" Margin="0,0,5,0" Padding="8,3" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="3">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <Button Content="♻️ Unblock" ToolTip="Unblock company and restore offers" Tag="{Binding}" Click="BtnOdblokovatFirmu_Click" Padding="8,3" Background="#F39C12" Foreground="White" BorderThickness="0" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="3">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Grid x:Name="GridSettings" Grid.Column="1" Margin="30" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="⚙️ Settings &amp; Filters" FontSize="32" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,20"/>
            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Add new URL to scrape:" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Name="txtNewUrl" Padding="10" FontSize="14" Margin="0,0,10,0"/>
                        <Button Grid.Column="1" Click="BtnAddUrl_Click" Content="Add URL" Background="#2980B9" Foreground="White" Padding="20,10" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                </StackPanel>
            </Border>
            <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20">
                <ListBox Name="lstUrls" DisplayMemberPath="Url" BorderThickness="0"/>
            </Border>
        </Grid>
    </Grid>
</Window>