<Window x:Class="JobSniper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:JobSniper.Properties"
        Title="{x:Static p:Resources.WindowTitle}" Height="800" Width="1200" 
        WindowStartupLocation="CenterScreen" Background="#F0F2F5" FontFamily="Segoe UI" Icon="pack://application:,,,/sniper1.ico">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="{x:Static p:Resources.AppTitle}" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Button x:Name="BtnDashboard" Click="BtnDashboard_Click" Content="{x:Static p:Resources.Menu_Dashboard}" Height="45" Margin="10,5" Background="#34495E" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="BtnTridicka" Click="BtnTridicka_Click" Content="{x:Static p:Resources.Menu_Inbox_Format}" Height="45" Margin="10,5" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                <Button x:Name="BtnPrilezitosti" Click="BtnPrilezitosti_Click" Content="{x:Static p:Resources.Menu_Opportunities_Format}" Height="45" Margin="10,5" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                <Button x:Name="BtnKos" Click="BtnKos_Click" Content="{x:Static p:Resources.Menu_Trash_Format}" Height="45" Margin="10,5" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                <Button x:Name="BtnArchiv" Click="BtnArchiv_Click" Content="{x:Static p:Resources.Menu_Archive_Format}" Height="45" Margin="10,5" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                <Button x:Name="BtnDuplicity" Click="BtnDuplicity_Click" Content="{x:Static p:Resources.Menu_Duplicates_Format}" Height="45" Margin="10,5" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                <Button x:Name="BtnCrmTab" Click="BtnCrmTab_Click" Content="{x:Static p:Resources.Menu_Crm}" Height="45" Margin="10,5" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>

                <Button x:Name="BtnSettings" Click="BtnSettings_Click" Content="{x:Static p:Resources.Menu_Settings}" Height="45" Margin="10,5" Background="Transparent" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
            </StackPanel>
        </Border>

        <Grid x:Name="GridDashboard" Grid.Column="1" Margin="30" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{x:Static p:Resources.Dashboard_Title}" FontSize="32" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,20"/>

            <Grid Grid.Row="1" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="{x:Static p:Resources.Dashboard_WaitingInbox}" FontSize="14" Foreground="#7F8C8D"/>
                        <TextBlock x:Name="TxtCekaVTridicce" Text="0" FontSize="36" FontWeight="Bold" Foreground="#2980B9" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" Margin="10,0,10,0">
                    <StackPanel>
                        <TextBlock Text="{x:Static p:Resources.Dashboard_MyOpportunities}" FontSize="14" Foreground="#7F8C8D"/>
                        <TextBlock x:Name="TxtMojePrilezitosti" Text="0" FontSize="36" FontWeight="Bold" Foreground="#27AE60" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{x:Static p:Resources.Dashboard_Trashed}" FontSize="14" Foreground="#7F8C8D"/>
                        <TextBlock x:Name="TxtZahozeno" Text="0 / 0" FontSize="36" FontWeight="Bold" Foreground="#E74C3C" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{x:Static p:Resources.Dashboard_BackgroundProcesses}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="#333"/>
                    <TextBox Name="TxtConsoleLog" Grid.Row="1" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Background="#1E1E1E" Foreground="LightGreen" FontFamily="Consolas" Padding="10"/>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="GridTridicka" Grid.Column="1" Margin="30" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TxtTridickaTitle" Grid.Column="0" Text="{x:Static p:Resources.Menu_Inbox_Format}" FontSize="32" FontWeight="SemiBold" Foreground="#333" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static p:Resources.Search_Label}" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtSearch" Width="250" Padding="8" FontSize="14" TextChanged="TxtSearch_TextChanged" ToolTip="{x:Static p:Resources.Search_Tooltip}"/>
                </StackPanel>
            </Grid>
            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10">
                <DataGrid Name="DataGridJobs" AutoGenerateColumns="False" IsReadOnly="True" Background="White" RowBackground="#F8F9FA" AlternatingRowBackground="White" BorderBrush="#EEE" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEE" VerticalContentAlignment="Center">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static p:Resources.Grid_Position}" Binding="{Binding Title}" Width="*" />
                        <DataGridTextColumn Header="Zdroj" Binding="{Binding PortalName}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#7F8C8D"/>
                                    <Setter Property="FontStyle" Value="Italic"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="{x:Static p:Resources.Grid_Company}" Width="180" SortMemberPath="Company">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Company}" Margin="5,0" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="3">
                                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="ToolTip" Value="{x:Static p:Resources.Tooltip_Blacklisted}"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding CrmReputation}" Value="1">
                                                        <Setter Property="Foreground" Value="#3498DB"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="ToolTip" Value="{x:Static p:Resources.Tooltip_CrmHistory}"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding CrmReputation}" Value="2">
                                                        <Setter Property="Foreground" Value="#F39C12"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="ToolTip" Value="{x:Static p:Resources.Tooltip_CrmWarning}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="{x:Static p:Resources.Grid_Location}" Binding="{Binding Location}" Width="150" />
                        <DataGridTextColumn Header="{x:Static p:Resources.Grid_Seen}" Binding="{Binding LastSeen, StringFormat=\{0:dd.MM. HH:mm\}}" Width="100" />
                        <DataGridTextColumn Header="{x:Static p:Resources.Grid_Salary}" Binding="{Binding Salary}" Width="130" />

                        <DataGridTemplateColumn Header="{x:Static p:Resources.Grid_Actions}" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="{x:Static p:Resources.Btn_Web}" Tag="{Binding Url}" Click="BtnOpenWeb_Click" Margin="0,0,5,0" Padding="8,3" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                                        <Button Content="📝" ToolTip="{x:Static p:Resources.Tooltip_Crm}" Tag="{Binding}" Click="BtnCrm_Click" Margin="0,0,5,0" Padding="8,3" Background="#9B59B6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                        <Button Content="👍" ToolTip="{x:Static p:Resources.Tooltip_Opportunity}" Tag="{Binding}" Click="BtnZajimave_Click" Margin="0,0,5,0" Padding="8,3" Background="#2ECC71" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                        <Button Content="👎" ToolTip="{x:Static p:Resources.Tooltip_Trash}" Tag="{Binding}" Click="BtnSkryt_Click" Margin="0,0,5,0" Padding="8,3" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                                        <Button Content="⛔" ToolTip="{x:Static p:Resources.Tooltip_Block}" Tag="{Binding}" Click="BtnBlokovatFirmu_Click" Margin="0,0,5,0" Padding="8,3" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="3">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <Button Content="{x:Static p:Resources.Btn_Unblock}" ToolTip="{x:Static p:Resources.Tooltip_Unblock}" Tag="{Binding}" Click="BtnOdblokovatFirmu_Click" Padding="8,3" Background="#F39C12" Foreground="White" BorderThickness="0" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="3">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Grid x:Name="GridSettings" Grid.Column="1" Margin="30" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{x:Static p:Resources.Menu_Settings}" FontSize="32" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,20"/>
            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="{x:Static p:Resources.Settings_AddUrlLabel}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" Name="txtNewUrl" Padding="10" FontSize="14" Margin="0,0,10,0"/>

                        <ComboBox Grid.Column="1" Name="CmbScrapers" Width="200" Margin="0,0,10,0" Padding="10" FontSize="14" VerticalContentAlignment="Center"/>

                        <Button Grid.Column="2" Click="BtnAddUrl_Click" Content="{x:Static p:Resources.Settings_BtnAddUrl}" Background="#2980B9" Foreground="White" Padding="20,10" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                </StackPanel>
            </Border>
            <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20">
                <ListBox Name="lstUrls" BorderThickness="0" HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Url}" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="#2C3E50"/>

                                <TextBlock Grid.Column="1" Text="{Binding PortalName, StringFormat=[{0}]}" Foreground="#7F8C8D" VerticalAlignment="Center" Margin="10,0" FontSize="13"/>

                                <Button Grid.Column="2" Content="❌" Tag="{Binding}" Click="BtnDeleteUrl_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Smazat tuto URL"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

        <Grid x:Name="GridCrm" Grid.Column="1" Margin="30" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{x:Static p:Resources.Crm_Title}" FontSize="32" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,20"/>

            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="{x:Static p:Resources.Crm_BtnAddCompany}" Click="BtnAddNewCompany_Click" Padding="15,8" Background="#2ECC71" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static p:Resources.Search_Label}" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtCrmSearch" Width="250" Padding="8" FontSize="14" TextChanged="TxtCrmSearch_TextChanged" ToolTip="Hledá v názvu, aliasech a historii interakcí"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10">
                <DataGrid Name="DataGridCrm" AutoGenerateColumns="False" IsReadOnly="True" Background="White" RowBackground="#F8F9FA" AlternatingRowBackground="White" BorderBrush="#EEE" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEE" VerticalContentAlignment="Center">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static p:Resources.Grid_CompanyName}" Binding="{Binding PrimaryName}" Width="250" />
                        <DataGridTemplateColumn Header="{x:Static p:Resources.Grid_Potential}" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock FontWeight="Bold" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="➖" />
                                                <Setter Property="Foreground" Value="#BDC3C7" />

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Potential}" Value="1">
                                                        <Setter Property="Text" Value="🟢 A" />
                                                        <Setter Property="Foreground" Value="#27AE60" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Potential}" Value="2">
                                                        <Setter Property="Text" Value="🟡 B" />
                                                        <Setter Property="Foreground" Value="#F39C12" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Potential}" Value="3">
                                                        <Setter Property="Text" Value="🟠 C" />
                                                        <Setter Property="Foreground" Value="#D35400" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Potential}" Value="4">
                                                        <Setter Property="Text" Value="⚪ E" />
                                                        <Setter Property="Foreground" Value="#7F8C8D" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="{x:Static p:Resources.Grid_Reputation}" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    
                                    <TextBlock Text="{Binding Reputation}" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Reputation}" Value="1">
                                                        <Setter Property="Foreground" Value="#3498DB"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Reputation}" Value="2">
                                                        <Setter Property="Foreground" Value="#F39C12"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="{x:Static p:Resources.Grid_LastContact}" Binding="{Binding LastInteraction, StringFormat=\{0:dd.MM.yyyy\}}" Width="120" />

                        <DataGridTemplateColumn Header="{x:Static p:Resources.Grid_Actions}" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{x:Static p:Resources.Btn_Edit}" Tag="{Binding}" Click="BtnEditCrm_Click" Margin="0,0,5,0" Padding="8,3" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                        <Button Content="{x:Static p:Resources.Btn_Delete}" Tag="{Binding}" Click="BtnDeleteCrm_Click" Padding="8,3" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>