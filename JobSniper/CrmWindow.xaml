<Window x:Class="JobSniper.CrmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:JobSniper.Properties"
        Title="{x:Static p:Resources.CrmWindow_Title}" Height="620" Width="500"
        WindowStartupLocation="CenterOwner" Background="#F0F2F5" FontFamily="Segoe UI" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Name="TxtCompanyName" Grid.Row="0" Text="{x:Static p:Resources.CrmWindow_CompanyName}" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="{x:Static p:Resources.CrmWindow_AliasesLabel}" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,5"/>
            <TextBox Name="TxtAliases" Padding="8" FontSize="14" ToolTip="{x:Static p:Resources.CrmWindow_AliasesTooltip}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="{x:Static p:Resources.CrmWindow_ReputationLabel}" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <RadioButton Name="RbNeutral" Content="{x:Static p:Resources.CrmWindow_RepNeutral}" IsChecked="True" Margin="0,0,15,0"/>
                <RadioButton Name="RbInfo" Content="{x:Static p:Resources.CrmWindow_RepInfo}" Foreground="#3498DB" FontWeight="Bold" Margin="0,0,15,0"/>
                <RadioButton Name="RbWarning" Content="{x:Static p:Resources.CrmWindow_RepWarning}" Foreground="#F39C12" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="{x:Static p:Resources.Pot_Label}" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,5"/>
            <ComboBox Name="CmbPotential" Padding="5" FontSize="14" Width="300" HorizontalAlignment="Left">
                <ComboBoxItem Content="{x:Static p:Resources.Pot_0}" Tag="0"/>
                <ComboBoxItem Content="{x:Static p:Resources.Pot_1}" Tag="1"/>
                <ComboBoxItem Content="{x:Static p:Resources.Pot_2}" Tag="2"/>
                <ComboBoxItem Content="{x:Static p:Resources.Pot_3}" Tag="3"/>
                <ComboBoxItem Content="{x:Static p:Resources.Pot_4}" Tag="4"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,20">
            <TextBlock Text="{x:Static p:Resources.CrmWindow_HistoryLabel}" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,5"/>
            <TextBox Name="TxtHistory" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="8" FontSize="14" Height="180"/>
            <CheckBox Name="ChkIsBlacklisted" Content="{x:Static p:Resources.CrmWindow_ChkBlocked}" Foreground="#E74C3C" FontWeight="Bold" Margin="0,15,0,0" Cursor="Hand"/>
        </StackPanel>

        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Click="BtnCancel_Click" Content="{x:Static p:Resources.CrmWindow_BtnCancel}" Width="100" Padding="10,8" Margin="0,0,10,0" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Grid.Column="2" Click="BtnSave_Click" Content="{x:Static p:Resources.CrmWindow_BtnSave}" Width="130" Padding="10,8" Background="#2ECC71" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>